<!DOCTYPE html><html lang="bg"><head><meta charset="UTF-8><meta charset="UTF-8" /><meta name="viewport" content="width=device-width, initial-scale=1.0" /><title>Travel Offer</title><link rel="stylesheet" href="/styles.css" /></head><body><div class="topbar"><div class="container topbar-inner"><div><div class="brand-title">2L1P Premium Client View</div><div class="brand-sub">Your personalized travel offer.</div></div><div class="actions"><a class="btn secondary" href="/">Home</a></div></div></div><div class="container hero" id="clientContainer"><div class="empty">Loading offer...</div></div><script>function fmtDate(v){try{return new Date(v).toLocaleString("bg-BG")}catch{return v||"-"}} function badge(s){return `<span class="badge ${s}">${s}</span>`} async function loadOffer(){const id=location.pathname.split("/").pop(); const res=await fetch(`/api/offers/${id}`); const data=await res.json(); const root=document.getElementById("clientContainer"); if(!data.success){root.innerHTML='<div class="empty">Offer not found.</div>';return;} const o=data.offer; root.innerHTML=`<div class="hero-banner"><div>${badge(o.effectiveStatus)}</div><h2>${o.destination||"Travel Offer"}</h2><p>${o.notes||"A personalized offer prepared for your trip."}</p></div><div class="grid grid-2" style="margin-top:18px;"><div class="card"><h2 class="section-title">Trip Overview</h2><div class="meta-grid"><div class="meta-box"><div class="label">Client</div><div class="value">${o.clientName||"Guest"}</div></div><div class="meta-box"><div class="label">Guests</div><div class="value">${o.guests||"-"}</div></div><div class="meta-box"><div class="label">Travel Dates</div><div class="value">${o.travelDates||"-"}</div></div><div class="meta-box"><div class="label">Flight Route</div><div class="value">${o.flightRoute||"To be confirmed"}</div></div><div class="meta-box"><div class="label">Hotel</div><div class="value">${o.hotel||"Flexible hotel options"}</div></div><div class="meta-box"><div class="label">Valid Until</div><div class="value">${fmtDate(o.validUntil)}</div></div></div><p class="muted">Offer ID: ${o.id}</p></div><div class="card"><h2 class="section-title">Price & Contact</h2><div class="price-line">${Number(o.price).toFixed(2)} ${o.currency}</div><div class="offer-sub">Prepared and personalized for direct client communication.</div><div class="meta-grid"><div class="meta-box"><div class="label">Offer Status</div><div class="value">${o.effectiveStatus}</div></div><div class="meta-box"><div class="label">Created</div><div class="value">${fmtDate(o.createdAt)}</div></div></div><div class="offer-actions" style="margin-top:16px;"><a class="btn" href="/api/offers/${o.id}/pdf" target="_blank">Open PDF</a><a class="btn success" target="_blank" href="https://wa.me/${o.clientPhone||""}?text=${encodeURIComponent(`Hello ${o.clientName||""}, your travel offer for ${o.destination} is ready. Offer ID: ${o.id}. Total: ${Number(o.price).toFixed(2)} ${o.currency}. View it here: ${location.href}`)}">WhatsApp Agent</a></div></div></div>`;} loadOffer();</script>  <script src="/date-format.js></script>`r`n</body></html>





